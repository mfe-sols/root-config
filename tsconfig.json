{
  "extends": "ts-config-single-spa",
  "files": ["src/org-root-config.ts"],
  "compilerOptions": {
    "declarationDir": "dist",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@mfe-sols/auth": [
        "../../libs/auth/src/index.ts",
        "node_modules/@mfe-sols/auth/dist/index.d.ts"
      ]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test*"]
}
